{
  "name": "ai-closet-server",
  "version": "1.0.0",
  "private": true,
  "description": "AI Closet Stylist — Backend A (data + retrieval + MCP server)",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "seed": "ts-node --transpile-only seed/seed.ts",
    "mcp": "ts-node --transpile-only src/mcp/server.ts",
    "mcp:test": "ts-node --transpile-only src/mcp/test-client.ts",
    "build": "tsc",
    "start": "node dist/src/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.0",
    "mongodb-memory-server": "^10.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
