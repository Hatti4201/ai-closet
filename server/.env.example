# Backend A — environment template. Copy to .env and adjust as needed.

PORT=4000

# DB: leave MONGO_URI EMPTY to use an in-memory MongoDB for local dev
# (no install, no daemon). Set it to the team's shared DB URI later to switch
# over — no code change required.
MONGO_URI=

# Auth is out of scope for Backend A (MVP = no auth); present for the shared env.
JWT_SECRET=

# LLM is Backend B's concern. Placeholders so the env shape is frozen now.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
