# Backend A — environment template. Copy to .env and adjust as needed.

PORT=4000

# DB: leave MONGO_URI EMPTY to use an in-memory MongoDB for local dev
# (no install, no daemon). Set it to the team's shared DB URI later to switch
# over — no code change required.
MONGO_URI=

# Auth is out of scope for Backend A (MVP = no auth); present for the shared env.
JWT_SECRET=

# LLM provider. LLM_* is the canonical name; AI_* is kept for the earlier local env.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Optional deployment/client integration.
CLIENT_URL=
API_BASE_URL=

# Optional legacy image/search providers.
UNSPLASH_ACCESS_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
